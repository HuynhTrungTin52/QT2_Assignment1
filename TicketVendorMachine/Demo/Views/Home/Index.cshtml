@{
    ViewData["Title"] = "Home Page";
}

<style>
    .home-button:visited {
        color: black;
    }
    html, body {
        margin: 0 !important;
        padding: 0 !important;
        overflow: hidden !important; 
        height: 100vh;
        width: 100vw;
    }

    .container, .body-content, main {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
    }

    header, footer, .navbar {
        display: none !important;
    }

    .hero-section {
        background-image: url('@Url.Content("~/Content/images/saigon.jpg")');
        background-size: cover;
        background-position: center;
        width: 100vw;
        height: 100vh;


        display: flex;
        justify-content: center;
        align-items: center;
    }

    .hero-glass-box {
        background-color: rgba(255, 255, 255, 0.4);
/*        backdrop-filter: blur(8px);*/
        padding: 60px 100px;
        border-radius: 20px;
        text-align: center;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .hero-title {
        font-family: 'Georgia', serif;
        font-size: 4.5rem;
        font-weight: 700;
        color: #111;
        margin-bottom: 40px;
        letter-spacing: 2px;
    }

    .btn-buy-ticket {
        background-color: #cf7c52;
        color: #000;
        font-size: 1.8rem;
        font-weight: bold;
        padding: 15px 50px;
        border-radius: 50px;
        text-decoration: none;
        transition: background-color 0.3s ease, transform 0.2s ease;
        display: inline-block;
        border: 2px solid #a85e38; 
    }

    .btn-buy-ticket:hover {
        background-color: #b06540;
        color: #fff; 
        text-decoration: none;
        transform: scale(1.05);
    }
</style>

<div class="hero-section">
    <div class="hero-glass-box">
        <h1 class="hero-title">Welcome to Saigon</h1>

        <a href="@Url.Action("Index", "Ticket")" class="btn-buy-ticket">Buy Ticket</a>
    </div>
</div>