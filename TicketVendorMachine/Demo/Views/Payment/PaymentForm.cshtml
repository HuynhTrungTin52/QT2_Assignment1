@model Demo.Models.Ticket
@{
    ViewBag.Title = "Select Payment Method";
}

<style>
   
    html, body { margin: 0 !important; padding: 0 !important; overflow: hidden !important; height: 100vh; width: 100vw; }
    .container, .body-content, main { padding: 0 !important; margin: 0 !important; max-width: 100% !important; }
    header, footer, .navbar { display: none !important; }

    .hero-section {
        background-image: url('@Url.Content("~/Content/images/saigon.jpg")');
        background-size: cover;
        background-position: center;
        width: 100vw;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .glass-panel {
        background-color: rgba(255, 255, 255, 0.4);
/*        backdrop-filter: blur(12px);*/
        border-radius: 20px;
        padding: 60px 150px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .total-banner {
        text-align: center;
        margin-bottom: 40px;
        color: #fff;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.8);
    }

    .total-banner h2 { font-size: 2rem; margin: 0; }
        .total-banner .amount {
            font-size: 3rem;
            font-weight: bold;
            color: #059d04;
            text-shadow: 1px 1px 2px #fff;
        }

    .button-container {
        display: flex;
        gap: 40px;
        justify-content: center;
    }

    .payment-btn {
        background-color: #ffffff;
        border: none;
        border-radius: 25px;
        width: 300px;
        height: 300px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .payment-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 15px 40px rgba(0,0,0,0.3);
    }

    .payment-icon {
        width: 100px;
        height: 100px;
        margin-bottom: 20px;
        fill: #333; 
    }

    .payment-text {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: #000;
    }
</style>

<div class="hero-section">
    <div class="glass-panel">

        <div class="total-banner">
            <h2>Total Due:</h2>
            <div class="amount">@Model.FinalPrice.ToString("0") vnđ</div>
        </div>

        @using (Html.BeginForm("ProcessPayment", "Payment", FormMethod.Post))
        {
            <input type="hidden" name="ticketId" value="@Model.TicketID" />

            <div class="button-container">

                <button type="submit" name="paymentMethod" value="QR Code" class="payment-btn">
                    <svg class="payment-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 3h6v6H3V3zm2 2v2h2V5H5zm8-2h6v6h-6V3zm2 2v2h2V5h-2zM3 13h6v6H3v-6zm2 2v2h2v-2H5zm13-2h-2v2h2v-2zm-2 2h-2v2h2v-2zm2 2h-2v2h2v-2zm-2 2h-2v2h2v-2zm2-6v-2h-2v2h2zm-4-2h-2v2h2v-2zm0 4h-2v2h2v-2z" fill-rule="evenodd" />
                        <path d="M10 10h2v2h-2zm4 0h2v2h-2zm-4 4h2v2h-2zm4 0h2v2h-2z" />
                    </svg>
                    <span class="payment-text">QR Code</span>
                </button>

                <button type="submit" name="paymentMethod" value="Credit Card" class="payment-btn">
                    <svg class="payment-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M20 4H4C2.89 4 2.01 4.89 2.01 6L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z" />
                    </svg>
                    <span class="payment-text">Credit Card</span>
                </button>

            </div>
        }
    </div>
</div>