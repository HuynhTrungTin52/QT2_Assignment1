@model IEnumerable<Demo.Models.Destination>
@{
    ViewBag.Title = "Select Destination";
}

<style>
   
    html, body {
        margin: 0 !important;
        padding: 0 !important;
        overflow: hidden !important;
        height: 100vh;
        width: 100vw;
    }

    .container, .body-content, main {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
    }

    header, footer, .navbar {
        display: none !important;
    }

    .hero-section {
        background-image: url('@Url.Content("~/Content/images/saigon.jpg")');
        background-size: cover;
        background-position: center;
        width: 100vw;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .glass-panel {
        background-color: rgba(255, 255, 255, 0.4);
/*        backdrop-filter: blur(8px);*/
        border-radius: 20px;
        padding: 40px;
        width: 750px; 
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .scrollable-list {
        max-height: 400px; 
        overflow-y: auto;
        padding-right: 15px; 
        margin-bottom: 20px;
    }

    .scrollable-list::-webkit-scrollbar { width: 12px; }
    .scrollable-list::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.2); border-radius: 10px; }
    .scrollable-list::-webkit-scrollbar-thumb { background: rgba(0, 0, 0, 0.5); border-radius: 10px; }
    .scrollable-list::-webkit-scrollbar-thumb:hover { background: rgba(0, 0, 0, 0.8); }

    .destination-label {
        display: block;
        margin-bottom: 15px;
        cursor: pointer;
    }

    .destination-label input[type="radio"] {
        display: none;
    }

    .option-pill {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: rgba(245, 245, 245, 0.95);
        border: 2px solid #333;
        border-radius: 50px;
        padding: 15px 40px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        font-size: 1.8rem;
        color: #000;
        transition: all 0.2s ease;
    }

    .price-text {
        color: #28a745; 
        font-weight: bold;
        font-size: 1.2rem;
    }

    .destination-label:hover .option-pill {
        background-color: #fff;
        transform: scale(1.02);
    }

    .destination-label input[type="radio"]:checked + .option-pill {
        background-color: #cf7c52;
        color: #fff;
        border-color: #a85e38;
    }

    .destination-label input[type="radio"]:checked + .option-pill .price-text {
        color: #fff; 
    }

    .action-row {
        display: flex;
        justify-content: flex-end; 
        margin-top: 10px;
    }

    .btn-next {
        background-color: #cf7c52;
        color: #000;
        font-size: 1.5rem;
        padding: 10px 40px;
        border-radius: 50px;
        border: 2px solid #a85e38;
        cursor: pointer;
        transition: 0.3s ease;
    }

    .btn-next:hover {
        background-color: #b06540;
        color: #fff;
    }
</style>

<div class="hero-section">
    <div class="glass-panel">

        @using (Html.BeginForm("Confirm", "Ticket", FormMethod.Post))
        {
            <input type="hidden" name="isStudent" value="false" />

            <div class="scrollable-list">


                @foreach (var dest in Model)
                {
                    <label class="destination-label">
                        <input type="radio" name="destinationId" value="@dest.DestinationID" required>
                        <span class="option-pill">
                            <span>@dest.StationName</span>
                            <span class="price-text">@dest.BaseFare.ToString("N0")</span>
                        </span>
                    </label>
                }


            </div>

            <div class="action-row">
                <button type="submit" class="btn-next">Next</button>
            </div>
        }

    </div>
</div>